    "@vitejs/plugin-react": "^4.3.4",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase": "^11.1.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  }
